# GitHub Personal Access Token (optional, for GitHub API)
GITHUB_TOKEN=your_github_token_here

# Product Hunt API Key (optional)
PH_API_KEY=your_product_hunt_api_key_here

# HTTP Proxy (optional)
HTTP_PROXY=http://proxy:port

# Admin default password (set after first login)
ADMIN_DEFAULT_PASSWORD=change_me_after_first_login

# Flask Secret Key (generate a random key for production)
FLASK_SECRET_KEY=your-secret-key-here

# Database path
DATABASE_PATH=custom_crawler.db

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
